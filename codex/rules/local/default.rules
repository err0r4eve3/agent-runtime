prefix_rule(pattern=["openclaw", "daemon", "restart"], decision="allow")
prefix_rule(pattern=["git", "-C", "/Users/error4ever/Dev/Projects/emby-bot", "push", "-u", "origin", "main"], decision="allow")
prefix_rule(pattern=["ssh", "fakaServer"], decision="allow")
prefix_rule(pattern=["uv", "run", "python", "-m", "pytest"], decision="allow")
