{
    "mcpServers": {
        "ghidra-mcp": {
            "command": "python",
            "args": [
                "bridge_mcp_ghidra.py",
                "--profile",
                "re",
                "--approval-mode",
                "never"
            ],
            "env": {
                "GHIDRA_SERVER_URL": "http://127.0.0.1:8089/"
            }
        },
        "ghidra-mcp-http": {
            "url": "http://127.0.0.1:8081/mcp",
            "note": "Use this config when running the bridge with: python bridge_mcp_ghidra.py --transport streamable-http --mcp-port 8081"
        }
    }
}
